{
    "name": "@live-connector/extension",
    "version": "2.12.0",
    "private": true,
    "type": "module",
    "main": "dist/extension.js",
    "scripts": {
        "build": "tsx build.ts",
        "build:production": "tsx build.ts --production",
        "package": "pnpm run build:production && tsx package.ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "start": "tsx build.ts && extensions-cli run"
    },
    "dependencies": {
        "@ableton-extensions/sdk": "file:../../ableton-sdk/ableton-extensions-sdk-1.0.0-beta.0.tgz",
        "@live-connector/cypher": "workspace:*",
        "@live-connector/env": "workspace:*",
        "@live-connector/error": "workspace:*",
        "@live-connector/log": "workspace:*",
        "@live-connector/lom-schema": "workspace:*",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@ungap/structured-clone": "^1.3.2",
        "abort-controller": "^3.0.0",
        "domexception": "^4.0.0",
        "event-target-shim": "^6.0.2",
        "undici": "^8.5.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@ableton-extensions/cli": "file:../../ableton-sdk/ableton-extensions-cli-1.0.0-beta.0.tgz",
        "esbuild": "^0.28.1",
        "tsx": "^4.22.4",
        "vitest": "^4.1.9"
    }
}
