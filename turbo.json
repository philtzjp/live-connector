{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "package": {
            "dependsOn": ["^build"],
            "outputs": ["dist/*.ablx"]
        },
        "typecheck": {
            "dependsOn": ["^typecheck"]
        },
        "test": {}
    }
}
